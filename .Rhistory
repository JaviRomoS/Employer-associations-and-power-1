library(pacman)
pacman::p_load(tidyverse, dplyr, haven, sjmisc, sjPlot, summarytools, survey, readxl)
encla <- readRDS("../output/subset1.rds")
ohl <- readxl::read_excel("../input/base_OHL.xlsx", col_types = "text")
# Crear variable pob
encla <- encla %>%
group_by(estrato) %>%
mutate(pob = sum(fe)) %>%
ungroup()
# Objeto encuesta
diseno_aut <- survey::svydesign(
ids = ~id,
strata = ~estrato,
weights = ~fe,
fpc = ~pob,
data = encla)
summary(encla$k3_3)
encla <- encla %>%
group_by(id) %>%
mutate(
union_density_expanded = case_when(
sum(b1_3_7 * fe, na.rm = TRUE) == 0 ~ NA_real_,
TRUE ~ (sum(k3_3 * fe, na.rm = TRUE) / sum(b1_3_7 * fe, na.rm = TRUE)) * 100)) %>%
ungroup()
encla %>% select(id,union_density,union_density_expanded) %>% View()
table(encla$iguales, useNA = "ifany")
encla %>%
mutate(diferencia = union_density - union_density_expanded)
encla %>%
mutate(diferencia = union_density - union_density_expanded) %>% select(id,union_density,union_density_expanded,diferencia)
rm(list = ls())
library(pacman)
pacman::p_load(tidyverse, dplyr, haven, sjmisc, sjPlot, summarytools, survey, readxl)
encla <- readRDS("../output/subset1.rds")
ohl <- readxl::read_excel("../input/base_OHL.xlsx", col_types = "text")
# Crear variable pob
encla <- encla %>%
group_by(estrato) %>%
mutate(pob = sum(fe)) %>%
ungroup()
# Objeto encuesta
diseno_aut <- survey::svydesign(
ids = ~id,
strata = ~estrato,
weights = ~fe,
fpc = ~pob,
data = encla)
encla <- encla %>%
group_by(economic_industry) %>%
mutate(union_density_sector = sum(k3_3, na.rm = TRUE) / sum(b1_3_7, na.rm = TRUE)) %>%
ungroup()
encla %>%
group_by(economic_industry) %>%
