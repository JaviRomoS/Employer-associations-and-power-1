ohl <- ohl %>%
mutate(
# Clasificación principal con ciuur2
ramas13 = case_when(
ciuur2 %in% 1:6 ~ 1,   # Agriculture, livestock, forestry and fishing
ciuur2 == 7 ~ 2,       # Mining
ciuur2 == 8 ~ 3,       # Manufacturing industry
ciuur2 == 9 ~ 4,       # Electricity, gas and water supply; Waste management
ciuur2 == 10 ~ 5,      # Construction
ciuur2 %in% 11:12 ~ 6, # Trade
ciuur2 %in% 13:14 ~ 7, # Transportation, storage, information and communications
ciuur2 == 15 ~ 8,      # Accommodation and food service activities
ciuur2 %in% 16:17 ~ 9, # Financial and insurance activities; Real estate activities
ciuur2 %in% 18:19 ~ 10,# Professional and technical activities; Administrative and support services
ciuur2 == 20 ~ 11,     # Education
ciuur2 == 21 ~ 12,     # Health and social work activities
ciuur2 %in% 22:23 ~ 13,# Artistic and recreational activities; Other services
TRUE ~ NA_real_
),
# Respaldo con ciuur4 si ciuur2 está vacío
ramas13_alt = case_when(
is.na(ciuur2) & ciuur4 %in% 1:6 ~ 1,
is.na(ciuur2) & ciuur4 == 7 ~ 2,
is.na(ciuur2) & ciuur4 == 8 ~ 3,
is.na(ciuur2) & ciuur4 == 9 ~ 4,
is.na(ciuur2) & ciuur4 == 10 ~ 5,
is.na(ciuur2) & ciuur4 %in% 11:12 ~ 6,
is.na(ciuur2) & ciuur4 %in% 13:14 ~ 7,
is.na(ciuur2) & ciuur4 == 15 ~ 8,
is.na(ciuur2) & ciuur4 %in% 16:17 ~ 9,
is.na(ciuur2) & ciuur4 %in% 18:19 ~ 10,
is.na(ciuur2) & ciuur4 == 20 ~ 11,
is.na(ciuur2) & ciuur4 == 21 ~ 12,
is.na(ciuur2) & ciuur4 %in% 22:23 ~ 13,
TRUE ~ NA_real_
),
# Respaldo final con ohl_ramas si ciuur2 y ciuur4 están vacíos
ramas13_ohl = case_when(
ohl_ramas %in% 1:6 ~ 1,
ohl_ramas == 7 ~ 2,
ohl_ramas == 8 ~ 3,
ohl_ramas == 9 ~ 4,
ohl_ramas == 10 ~ 5,
ohl_ramas %in% 11:12 ~ 6,
ohl_ramas %in% 13:14 ~ 7,
ohl_ramas == 15 ~ 8,
ohl_ramas %in% 16:17 ~ 9,
ohl_ramas %in% 18:19 ~ 10,
ohl_ramas == 20 ~ 11,
ohl_ramas == 21 ~ 12,
ohl_ramas %in% 22:23 ~ 13,
TRUE ~ NA_real_
),
# Combinar todo: primero ramas13, luego respaldo con ramas13_alt y ramas13_ohl
ramas13 = coalesce(ramas13, ramas13_alt, ramas13_ohl)
) %>%
mutate(
# Convertir a factor con etiquetas en inglés
ramas13 = factor(ramas13,
levels = 1:13,
labels = c("Agriculture, livestock, forestry and fishing",
"Mining",
"Manufacturing industry",
"Electricity, gas and water supply; Waste management",
"Construction",
"Trade",
"Transportation, storage, information and communications",
"Accommodation and food service activities",
"Financial and insurance activities; Real estate activities",
"Professional and technical activities; Administrative and support services",
"Education",
"Health and social work activities",
"Artistic and recreational activities; Other services"))
)
ohl %>%
group_by(ramas13) %>%
count(yr, ramas13, name = "n") %>% View()
